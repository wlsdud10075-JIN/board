APP_NAME=board
APP_ENV=local
# ⚠️ 운영: php artisan key:generate 로 1회 생성 후 절대 변경 금지.
#    payee_account(계좌번호)가 이 키로 암호화됨 → 키 바뀌면 기존 암호문 복호화 불가.
#    car-erp 와 분리된 board 전용 키. 생성 후 안전한 곳에 백업.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Seoul

APP_LOCALE=ko
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ko_KR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── DB (운영 = MySQL board 전용 user, car_erp 접근 권한 0) ───
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=board
DB_USERNAME=board_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 큐 워커(Supervisor queue:work)로 연동 A/B Job·webhook 비동기 처리
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── 검차 사진/영상 저장 (운영 = s3) ───
# 로컬=public, 운영=s3 (바이어 공유 presigned 위해). car-erp 버킷 prefix 재사용.
BOARD_PHOTO_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── DB 백업 (db:backup) ───
# 운영: 원격(off-instance) 보관 위해 s3 권장. 비우면 로컬만.
DB_BACKUP_DISK=
# 리눅스는 보통 PATH 에 있어 생략 가능. Windows 로컬은 자동 경로.
# MYSQLDUMP_PATH=mysqldump

# ─── board 도메인 설정 (config/board.php) ───
BOARD_AUCTION_LOCK_TIME=10:00
BOARD_SALES_FEE=440000
BOARD_DEFAULT_KRW_PER_USD=1380
BOARD_DEFAULT_KRW_PER_EUR=1500
BOARD_RATE_TTL_HOURS=1
BOARD_RATE_API_BASE=https://api.frankfurter.app
BOARD_RATE_AUTO_REFRESH=true

# ─── 연동 B: car-erp purchase-sync (대표 승인 후) ───
CAR_ERP_BASE_URL=
CAR_ERP_HMAC_SECRET=
# 영업 포털 읽기 API(HMAC GET) 전용 시크릿 — car-erp board-portal-api.md §1. 미설정 시 no-op.
CAR_ERP_READ_HMAC_SECRET=

# ─── 연동 A: respond.io (도메인+HTTPS 후) ───
RESPOND_API_TOKEN=
RESPOND_WEBHOOK_SECRET=

# ─── ssancar 차량 미디어 API (검차영상 Bunny embed/hls + 사진) ───
# 두 인스턴스 동일(하나의 ssancar.com). 미설정 시 바이어페이지에 ssancar 미디어 no-op(에러 X).
SSANCAR_MEDIA_BASE_URL=https://www.ssancar.com/page/api_car_media.php
SSANCAR_MEDIA_API_KEY=

VITE_APP_NAME="${APP_NAME}"
